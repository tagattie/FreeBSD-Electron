{
  "name": "hyper-root",
  "version": "4.0.0-q-canary.13",
  "repository": "quine-global/hyper",
  "engines": {
    "node": "22.22.2"
  },
  "scripts": {
    "start": "echo 'please run `pnpm run dev` in one tab and then `pnpm run app` in another one'",
    "app": "cross-env ELECTRONMON_LOGLEVEL=error electronmon target",
    "app:parallels": "cross-env ELECTRONMON_LOGLEVEL=error HYPER_DISABLE_GPU=1 electronmon target",
    "dev": "concurrently -n \"Webpack,TypeScript\" -c \"cyan.bold,blue.bold\" \"webpack -w\" \"tsc --build -v --pretty --watch --preserveWatchOutput\" -k",
    "ts": "tsc --build -v --pretty --preserveWatchOutput",
    "build": "cross-env NODE_ENV=production webpack && tsc -b -v && cross-env BABEL_ENV=production babel target/renderer/bundle.js --out-file target/renderer/bundle.js --no-comments --minified",
    "lint": "eslint . --fix --ext .js,.jsx,.ts,.tsx,.json",
    "lint:ci": "eslint . --ext .js,.jsx,.ts,.tsx,.json",
    "test": "pnpm run test:unit",
    "test:unit": "zx test-unit.mjs",
    "test:unit:watch": "pnpm run test:unit -- --watch",
    "test:e2e": "cross-env DEBUG=ava:watcher AVA_IMPORT_FROM_PROJECT_NO_STUB=1 ava --no-cache --config ava-e2e.config.js",
    "postinstall": "pnpm run v8-snapshot && webpack --config-name hyper-app && pnpm run install-app-deps-with-retry && pnpm run rebuild-node-pty && cpy --cwd=target node_modules \"../../app/\" && husky && pnpm run generate-schema",
    "install-app-deps-with-retry": "node bin/with-normalized-cwd.js electron-builder install-app-deps || node bin/with-normalized-cwd.js electron-builder install-app-deps || node bin/with-normalized-cwd.js electron-builder install-app-deps",
    "rebuild-node-pty": "node bin/with-normalized-cwd.js electron-rebuild -f -o node-pty -m target",
    "dist": "pnpm run build && pnpm run electron-builder-with-retry",
    "electron-builder-with-retry": "electron-builder -p never || electron-builder -p never || electron-builder -p never",
    "clean": "node ./bin/rimraf-standalone.js node_modules && node ./bin/rimraf-standalone.js ./app/node_modules && node ./bin/rimraf-standalone.js ./app/renderer && node ./bin/rimraf-standalone.js ./target && node ./bin/rimraf-standalone.js ./dist",
    "v8-snapshot": "cross-env SNAPSHOT_TARGET_ARCH=x64 pnpm run v8-snapshot:arch && cross-env SNAPSHOT_TARGET_ARCH=arm64 pnpm run v8-snapshot:arch",
    "v8-snapshot:arch": "pnpm run mk-snapshot && pnpm run cp-snapshot",
    "mk-snapshot": "node bin/download-mksnapshot.js && node bin/mk-snapshot.js",
    "cp-snapshot": "node bin/cp-snapshot.js",
    "generate-schema": "typescript-json-schema ./typings/config.d.ts rawConfig -o ./app/config/schema.json --required",
    "uuaw": "uuaw"
  },
  "license": "MIT",
  "author": {
    "name": "ZEIT, Inc.",
    "email": "team@zeit.co"
  },
