    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "postcss-preset-env": "^11.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-tsc": "^2.2.12"
  }
