{
  "name": "electron-shogi",
  "version": "1.27.3",
  "description": "Shogi Frontend Application",
  "author": "Kubo, Ryosuke",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunfish-shogi/shogihome.git"
  },
  "keywords": [
    "shogi"
  ],
  "bugs": {
    "url": "https://github.com/sunfish-shogi/shogihome/issues"
  },
  "homepage": "https://github.com/sunfish-shogi/shogihome#readme",
  "type": "module",
  "scripts": {
    "audit:scripts": "tsx scripts/audit-scripts.ts",
    "install:esbuild": "npm run audit:scripts && node node_modules/esbuild/install.js",
    "install:electron": "npm run audit:scripts && node node_modules/electron/install.js",
    "compile": "npm run install:esbuild && vite build",
    "serve": "npm run install:esbuild && vite -c vite.config-pwa.mts",
    "build": "npm run install:esbuild && vite build -c vite.config-pwa.mts --outDir docs/webapp",
    "build:dev": "npm run install:esbuild && vite build -c vite.config-pwa.mts --outDir docs/webapp-dev",
    "preview": "npm run install:esbuild && vite preview",
    "test": "npm run install:esbuild && npm run install:electron && vitest run",
    "bench": "npm run install:esbuild && npm run install:electron && vitest bench",
    "coverage": "npm test -- --coverage",
    "test:ui": "npm run install:esbuild && npm run install:electron && vitest --ui --coverage",
    "lint": "vue-tsc --noEmit && eslint --fix --max-warnings 0 . && prettier --write .",
    "electron:compile": "npm run install:electron && tsc --project ./tsconfig.bg.json && tsc-alias && webpack --config-name preload",
    "electron:compile-all": "npm run compile && npm run electron:compile",
    "electron:pack": "npm run electron:compile-all && webpack --config-name background",
    "electron:serve": "npm run electron:compile && concurrently --kill-others vite \"electron --remote-debugging-port=9223 .\" \"tsc --project ./tsconfig.bg.json --sourceMap -w\" \"tsc-alias -w\" \"node ./scripts/fake-release-api.mjs\"",
    "electron:build": "npm run electron:pack && node scripts/build.mjs",
    "electron:portable": "npm run electron:pack && node scripts/build.mjs portable",
    "electron:preview": "npm run electron:compile-all && electron .",
    "license": "node scripts/report-license.mjs",
    "license:commit": "npm run license && git add . && git commit -m \"license\" || git diff",
    "docs": "tsx scripts/build-docs-templates.ts",
    "release": "npm run build && npm run build:dev && git add . && git commit -m \"release\"",
    "release:patch": "npm run license:commit && npm version patch && tsx scripts/publish-release.ts && npm run docs && npm run release",
    "release:minor": "npm run license:commit && npm version minor && tsx scripts/publish-release.ts && npm run docs && npm run release",
    "release:alpha": "npm run license:commit && npm version preminor --preid alpha",
    "release:beta": "npm run license:commit && npm version preminor --preid beta",
    "release:pre": "npm run license:commit && npm version prerelease",
    "release:stable": "tsx scripts/publish-release.ts stable && npm run docs && git add . && git commit -m \"update stable version\"",
    "usi-csa-bridge:build": "webpack --config-name command:usi-csa-bridge && node scripts/distribute-command.mjs usi-csa-bridge",
    "usi-csa-bridge:install": "npm run usi-csa-bridge:build && npm install -g ./dist/command/usi-csa-bridge"
  },
  "main": "dist/src/background/index.js",
  "module": "dist/src/background/index.js",
  "dependencies": {
    "@github/hotkey": "^3.1.0",
    "async-lock": "^1.4.0",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.19",
    "electron-context-menu": "^4.0.5",
    "encoding-japanese": "^2.0.0",
    "jimp": "^1.6.0",
    "log4js": "^6.7.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.4",
    "splitpanes": "^4.0.3",
    "tsshogi": "^2.3.3",
    "vue": "^3.5.29",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/async-lock": "^1.4.0",
    "@types/encoding-japanese": "^2.0.1",
    "@types/license-checker": "^25.0.6",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.5.8",
    "@types/splitpanes": "^2.2.1",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.2.1",
    "archiver": "^7.0.1",
    "concurrently": "^9.0.1",
    "depcheck": "^1.4.7",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.1.0",
    "jsdom": "^27.3.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.8.1",
    "terser-webpack-plugin": "^5.3.15",
    "ts-loader": "^9.5.2",
    "tsc-alias": "^1.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.2.5",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  }
}
