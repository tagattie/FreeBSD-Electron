{
  "$schema": "./package.schema.json",
  "packageManager": "pnpm@10.28.1",
  "name": "session-desktop",
  "productName": "Session",
  "description": "Private messaging from your desktop",
  "version": "1.18.0",
  "license": "GPL-3.0",
  "author": {
    "name": "Session Foundation",
    "email": "contact@session.foundation"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/session-foundation/session-desktop.git"
  },
  "main": "ts/mains/main_node.js",
  "resolutions": {
    "lodash": "^4.17.21",
    "react": "19.2.1",
    "@types/react": "^19.0.0",
    "@types/node": "^24.10.8",
    "nanoid": "^3.3.8",
    "csstype": "^3.1.3",
    "reselect": "5.1.1",
    "redux": "5.0.1",
    "linkify-it": "^5.0.0",
    "uc.micro": "^2.1.0"
  },
  "scripts": {
    "start-prod": "cross-env NODE_ENV=production NODE_APP_INSTANCE=devprod$MULTI electron ./app",
    "start-prod:pretty": "pnpm start-prod | pino-pretty",
    "start-dev": "cross-env NODE_ENV=development NODE_APP_INSTANCE=devprod$MULTI electron ./app",
    "start-dev:pretty": "pnpm start-dev | pino-pretty",
    "start-perf": "cross-env NODE_ENV=development NODE_APP_INSTANCE=devprod$MULTI electron --inspect-brk=9229 --enable-precise-memory-info --js-flags=\"--expose-gc --allow-natives-syntax\" ./app",
    "start-dev:perf": "pnpm start-perf | pino-pretty",
    "update-git-info": "node ./build/updateLocalConfig.js",
    "clean": "pnpx tsx ./build/clean.ts",
    "build:protobuf": "pbjs --target static-module --wrap commonjs --out ts/protobuf/compiled.js protos/*.proto && pbts --out ts/protobuf/compiled.d.ts ts/protobuf/compiled.js --force-long",
    "build:sass": "webpack --config=./sass.config.js",
    "build:svg": "webpack --config svgs.webpack.config.js",
    "build:setup": "pnpm print-deps && pnpm clean && pnpm update-git-info && pnpm build:protobuf && pnpm build-copy",
    "build:workers": "pnpm worker:utils && pnpm worker:libsession && pnpm worker:image_processor",
    "build-copy": "pnpx tsx ./build/copySource.ts",
    "build-deps": "concurrently -n SASS,SVG,UTIL,LIBSESSION,IMAGE -c blue,blue,blue,blue,blue \"pnpm build:sass\" \"pnpm build:svg\" \"pnpm worker:utils\" \"pnpm worker:libsession\" \"pnpm worker:image_processor\"",
    "build-compile": "babel dist --out-dir app --extensions .js",
    "build-ts-prod": "tsc && pnpm build-compile",
    "build-ts-source-maps": "tsc --sourceMap --inlineSources && pnpm build-compile",
    "build": "pnpm build:setup && pnpm build-ts-prod && pnpm build-deps",
    "build:dev": "pnpm build:setup && cross-env SESSION_RC_ALLOW_ERRORS=1 pnpm build-ts-source-maps && pnpm build-deps",
    "build-minify": "node minify.js",
    "build-no-compiler": "pnpm build:setup && tsc --outDir ./app/ts && pnpm build-deps && pnpm build-copy",
    "lint": "pnpm format --cache && eslint --cache .",
    "format": "prettier --list-different --write \"*.{css,js,json,scss,ts,tsx}\" \"./**/*.{css,js,json,scss,ts,tsx}\"",
    "start-prod-test": "cross-env NODE_ENV=production NODE_APP_INSTANCE=$MULTI electron .",
    "test-copy": "pnpx tsx ./build/copyTests.ts",
    "test-mocha": "cross-env IS_UNIT_TEST=1 mocha",
    "test": "pnpm test-copy && pnpm test-mocha",
    "test-hoisted": "pnpm test-copy && pnpx tsx ./build/copyBin.ts && cd app && pnpm test-mocha",
    "build-release-base": "cross-env NODE_ENV=production electron-builder --config.directories.app=app --config.extraMetadata.environment=production",
    "build-release": "pnpm build-release-base --publish=never",
    "build-release-publish": "pnpm build-release-base --publish=always",
    "ready": "pnpm dedupe --check && pnpm build && pnpm lint && pnpm test",
    "postinstall": "pnpm patch-package && pnpm electron-builder install-app-deps && pnpm build:protobuf",
    "worker:utils": "webpack --config=./utils.worker.config.js",
    "worker:libsession": "webpack --config=./libsession.worker.config.js",
    "worker:image_processor": "webpack --config=./image_processor.worker.config.js",
    "prepare": "husky",
    "print-deps": "node -v",
    "watch": "pnpm build:setup && concurrently -n TS,BABEL,SASS,SVG,UTIL,LIBSESSION,IMAGE -c green,blue,blue,blue,blue,blue,blue \"tsc --sourceMap --inlineSources --watch\" \"pnpm build-compile --watch\" \"pnpm build:sass --watch\" \"pnpm build:svg --watch\" \"pnpm worker:utils --watch\" \"pnpm worker:libsession --watch\" \"pnpm worker:image_processor --watch\""
  },
  "dependencies": {
    "@emoji-mart/data": "https://github.com/session-foundation/session-emoji-mart/releases/download/v5.6.0/emoji-mart-data-v1.2.1.tgz",
    "@emoji-mart/react": "https://github.com/session-foundation/session-emoji-mart/releases/download/v5.6.0/emoji-mart-react-v1.1.1.tgz",
    "@emotion/is-prop-valid": "1.2.2",
    "@emotion/memoize": "0.8.1",
    "@reduxjs/toolkit": "^2.11.1",
    "@signalapp/sqlcipher": "3.1.0",
    "abort-controller": "3.0.0",
    "auto-bind": "^4.0.0",
    "blob-util": "2.0.2",
    "buffer-crc32": "1.0.0",
    "bytebuffer": "^5.0.1",
    "clsx": "^2.1.1",
    "config": "3.3.12",
    "curve25519-js": "https://github.com/session-foundation/curve25519-js",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.4",
    "dotenv": "^17.3.1",
    "electron-localshortcut": "^3.2.1",
    "electron-updater": "^6.3.9",
    "emoji-mart": "https://github.com/session-foundation/session-emoji-mart/releases/download/v5.6.2/emoji-mart-v5.6.2.tgz",
    "filesize": "10.1.6",
    "firstline": "^2.0.2",
    "focus-trap-react": "^11.0.4",
    "framer-motion": "^12.5.0",
    "fs-extra": "11.3.0",
    "image-type": "^4.1.0",
    "libsession_util_nodejs": "https://github.com/session-foundation/libsession-util-nodejs/releases/download/v0.6.17/libsession_util_nodejs-v0.6.17.tar.gz",
    "libsodium-wrappers-sumo": "^0.7.15",
    "linkify-it": "^5.0.0",
    "lodash": "^4.17.21",
    "long": "^4.0.0",
    "maxmind": "^4.3.24",
    "mic-recorder-to-mp3": "^2.2.2",
    "node-fetch": "^2.7.0",
    "os-locale": "5.0.0",
    "p-retry": "^4.6.2",
    "p-timeout": "4.1.0",
    "pino": "^9.6.0",
    "protobufjs": "^7.4.0",
    "punycode": "^2.3.1",
    "qrcode.react": "4.2.0",
    "react": "19.2.1",
    "react-contexify": "https://github.com/session-foundation/session-react-contexify/releases/download/v7.0.0/react-contexify-7.0.0.tgz",
    "react-dom": "19.2.1",
    "react-draggable": "4.5.0",
    "react-h5-audio-player": "3.10.1",
    "react-intersection-observer": "10.0.0",
    "react-redux": "9.2.0",
    "react-toastify": "10.0.0",
    "react-use": "17.6.0",
    "react-virtualized": "9.22.6",
    "read-last-lines": "1.8.0",
    "redux": "5.0.1",
    "redux-promise-middleware": "6.2.0",
    "reselect": "5.1.1",
    "sanitize.css": "^12.0.1",
    "semver": "^7.7.1",
    "sharp": "https://github.com/session-foundation/sharp/releases/download/v0.34.5/sharp-0.34.5.tgz",
    "styled-components": "6.1.19",
    "uuid": "11.1.0",
    "webrtc-adapter": "^4.2.2",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.28.5",
    "@babel/preset-env": "7.28.5",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/babel__core": "7.20.5",
    "@types/babel__preset-env": "7.10.0",
    "@types/buffer-crc32": "^0.2.4",
    "@types/bytebuffer": "^5.0.49",
    "@types/chai": "4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/config": "3.3.5",
    "@types/electron-localshortcut": "^3.1.3",
    "@types/eslint": "~9.6.1",
    "@types/eslint-plugin-mocha": "~10.4.0",
    "@types/events": "~3.0.3",
    "@types/firstline": "^2.0.4",
    "@types/fs-extra": "11.0.4",
    "@types/jsdom": "^21.1.7",
    "@types/jsdom-global": "~3.0.7",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/linkify-it": "^5.0.0",
    "@types/lodash": "^4.17.16",
    "@types/long": "3.0.32",
    "@types/mocha": "5.2.7",
    "@types/node-fetch": "^2.5.7",
    "@types/punycode": "~2.1.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-virtualized": "~9.22.3",
    "@types/sass-loader": "~8.0.10",
    "@types/semver": "7.5.8",
    "@types/sinon": "9.0.11",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "8.53.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "chai-bytes": "^0.1.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "csstype": "^3.2.3",
    "electron": "40.0.0",
    "electron-builder": "26.7.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-import-resolver-typescript": "3.9.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-mocha": "^10.5.0",
    "eslint-plugin-more": "^1.0.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "events": "^3.3.0",
    "glob": "^13.0.1",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "jsdom-global": "^3.0.2",
    "mini-css-extract-plugin": "^2.9.2",
    "mocha": "11.1.0",
    "node-loader": "^2.1.0",
    "patch-package": "^7.0.2",
    "pino-pretty": "13.0.0",
    "prettier": "3.5.3",
    "protobufjs-cli": "^1.1.3",
    "react-error-boundary": "5.0.0",
    "rimraf": "^6.1.2",
    "sass": "^1.85.1",
    "sass-loader": "^16.0.5",
    "sinon": "19.0.2",
    "source-map": "^0.7.6",
    "terser": "^5.44.1",
    "ts-loader": "^9.5.2",
    "typescript": "5.8.2",
    "typescript-eslint": "8.53.1",
    "webpack": "5.103.0",
    "webpack-cli": "6.0.1"
  },
  "engines": {
    "node": "24.12.0"
  },
  "build": {
    "appId": "com.loki-project.messenger-desktop",
    "afterSign": "build/notarize.js",
    "afterPack": "build/afterPackHook.js",
    "artifactName": "${name}-${os}-${arch}-${version}.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "./build/launcher-script.sh",
        "to": "./launcher-script.sh"
      },
      "dynamic_assets/GeoLite2-Country.mmdb",
      "dynamic_assets/service-nodes-cache.json"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "icon": "build/icon-mac.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "notarize": false,
      "bundleVersion": "1",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "minimumSystemVersion": "13.0.0",
      "extendInfo": {
        "NSCameraUsageDescription": "Session requires camera access to record video.",
        "NSMicrophoneUsageDescription": "Session requires microphone access to record audio."
      }
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "signtoolOptions": {
        "publisherName": "Session Technology Stiftung"
      },
      "verifyUpdateCodeSignature": false,
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "rpm": {
      "fpm": [
        "--rpm-rpmbuild-define",
        "_build_id_links none"
      ]
    },
    "nsis": {
      "deleteAppDataOnUninstall": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "installerSidebar": "build/installer-sidebar.bmp"
    },
    "linux": {
      "category": "Network;InstantMessaging;Chat",
      "target": "deb",
      "icon": "build/icon-linux.icns",
      "files": [
        "node_modules/@img/sharp-libvips*",
        "!node_modules/@img/sharp-libvips*/lib/*.a*",
        "!node_modules/@img/sharp-libvips*/lib/*.so*"
      ]
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3",
        "libasound2",
        "libxss1"
      ],
      "packageCategory": "net"
    },
    "files": [
      "package.json",
      "preload.js",
      "about_preload.js",
      "settings_preload.js",
      "password_preload.js",
      "stylesheets/fonts.css",
      "stylesheets/dist/*",
      "config/**.json",
      "*.html",
      "mnemonic_languages/**.json",
      "protos/*",
      "ts/**/*.js",
      "!dist/**",
      "!app/**",
      "build/afterPackHook.js",
      "build/launcher-script.sh",
      "!build/*.js",
      "!build/*.ts",
      "images/**",
      "fonts/*",
      "sound/*",
      "!node_modules/@types",
      "!node_modules/lamejs/testdata/*",
      "!**/node_modules/.bin",
      "!**/node_modules/*/build/**",
      "!**/*.{o,hprof,orig,pyc,pyo,rbc}",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,__pycache__,thumbs.db,.gitignore,.gitattributes,.editorconfig,.flowconfig,.idea,appveyor.yml,.travis.yml,circle.yml,npm-debug.log,,pnpm-lock.yml,.map,.prettierrc,.nvmrc,.gitmodules,.clang-format,.CMakeLists.txt}",
      "!**/*.ts",
      "!**/*.cts",
      "!**/*.mts",
      "!**/*.map",
      "node_modules/zod/**",
      "!node_modules/zod/mini",
      "!node_modules/zod/src",
      "!node_modules/zod/v3",
      "!node_modules/zod/v4-mini",
      "!node_modules/zod/v4/mini",
      "node_modules/zod/v4/locales/*.cjs",
      "node_modules/linkify-it/**/*",
      "!node_modules/linkify-it/**/*.mjs",
      "!node_modules/linkify-it/node_modules/**",
      "node_modules/linkify-it/node_modules/uc.micro/build/index.cjs.js",
      "node_modules/uc.micro/build/index.cjs.js",
      "!node_modules/uc.micro/**/*.mjs",
      "node_modules/libsession_util_nodejs/build/Release/*.node",
      "node_modules/react-draggable/build/cjs/*.js",
      "node_modules/react-draggable/build/cjs/utils/*.js",
      "!node_modules/@signalapp/sqlcipher/prebuilds/*",
      "node_modules/@signalapp/sqlcipher/prebuilds/${platform}-${arch}/*.node",
      "!node_modules/libsession_util_nodejs/libsession-util/*",
      "!node_modules/libsession_util_nodejs/src/*",
      "ts/webworker/workers/node/libsession/*.node",
      "!dev-app-update.yml",
      "service-nodes-cache.json"
    ]
  }
}
